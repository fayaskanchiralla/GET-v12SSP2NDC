1090  lfsl("windoffshore", class, reg, slice) = lf_windoffshore(slice, class, reg);
1091  lfsl("pvrooftop", class, reg, slice) = lf_pvrooftop(slice, class, reg);
1092  lfsl("pvplantA", class, reg, slice) = lf_pvplantA(slice, class, reg);
1093  lfsl("pvplantB", class, reg, slice) = lf_pvplantB(slice, class, reg);
1094  lfsl("cspplantA", class, reg, slice) = lf_cspplantA(slice, class, reg);
