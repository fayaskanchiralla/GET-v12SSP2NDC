2393  engines.fx(trsp_fuel, "FC", trsp_mode, reg,t)$(year(t)<2030)=0;
2394  engines.fx(trsp_fuel, "hyb", trsp_mode, reg,t)$(year(t)<2020)=0.0;
2395  engines.fx(trsp_fuel, "FCREEV", trsp_mode, reg,t)$(year(t)<2030)=0.0;
2396  engines.fx("LCH4", engine_type, trsp_mode, reg,t)$(year(t)<2020)=0;
2397  engines.fx("MeOH", engine_type, trsp_mode, reg,t)$(year(t)<2020)=0;
2398  engines.fx("LH2", engine_type, trsp_mode, reg,t)$(year(t)<2030)=0;
2399  engines.fx("NH3", engine_type, trsp_mode, reg,t)$(year(t)<2030)=0;
2400  engines.fx("CH2", engine_type, trsp_mode, reg,t)$(year(t)<2030)=0;
2401   
2402  engines.fx(trsp_fuel, "BEV", "f_HDT_RD", reg,t)$(year(t)<2040)=0.0;
2403  engines.fx(trsp_fuel, "PHEV", "f_HDT_RD", reg,t)$(year(t)<2040)=0.0;
2404  engines.fx(trsp_fuel, "BEV", "f_HDT_LH", reg,t)$(year(t)<2040)=0.0;
2405  engines.fx(trsp_fuel, "PHEV", "f_HDT_LH", reg,t)$(year(t)<2040)=0.0;
2406  engines.fx(trsp_fuel, "hyb", "f_HDT_LH", reg,t)$(year(t)<2030)=0.0;
2407  engines.fx(trsp_fuel, "hyb", "f_HDT_LH", reg,t)$(year(t)<2030)=0.0;
2408   
2409  EN_CONV.lo("bio","MeOH","0",reg,"2020")=trsp_cal_road_2020(reg, "MeOH")/effic_0("bio","0","MeOH");
2410   
2411  *------agrifeedstock---------
2412  * H2 only to NH3 before 2030
2413  en_conv.fx("H2", en_out, type, reg, t)$((year(t) < 2030) and not sameas(en_out, "agrifeedstock")) = 0;
2414   
2415  en_conv.fx("NH3", en_out, type, reg, t)$(year(t) < 2030) = 0;
2416  en_conv.fx(en_in, "H2", type, reg, t)$((year(t) < 2030) and not sameas(en_in, "CH4") and not sameas(type,"0")) = 0;
2417   
2418  *trsp_energy.fx(trsp_fuel, engine_type, trsp_mode, reg,t)$(trsp_conv(trsp_fuel, engine_type, trsp_mode)=0) =  0;
2419  capital.fx(en_in,en_out,type,reg,t) $ (effic_0(en_in,type,en_out) eq 0) = 0;
2420  EN_CONV.fx(en_in,en_out,type,reg,t) $ (effic_0(en_in,type,en_out) eq 0) = 0;
2421   
2422   
2423  *------------Initial energy conversion levels------------------
2424  *capital.fx(en_in,"MeOH",type,reg,t)$(year(t)<2020) = 0;
2425  capital.UP(en_in,"ethanol",type,reg,t)$(year(t)<2020) = 0;
2426  capital.UP(en_in,"biogas",type,reg,t)$(year(t)<2020) = 0;
2427  capital.UP(en_in,"biodiesel",type,reg,t)$(year(t)<2020) = 0;
2428   
2429  capital.UP("MOX","elec",type,reg,t)$(year(t)< 2020)= 0;
2430  capital.UP("EU4","H2",type,reg,t) $(year(t)< 2030)= 0;
2431  capital.UP("FBF","elec",type,reg,t) $(year(t)< 2030)= 0;
2432  capital.UP("solar","elec","cg",reg,"2010")= 0;
2433  *capital.up(en_in, "H2", type,reg, t)$(year(t)< 2020)= 0;
2434  *capital.up("H2", en_out, type,reg, t)$(year(t)< 2020)= 0;
2435  capital.UP("pellets",en_out,type,reg,t)$(year(t)< 2020)= 0;
2436  capital.UP("EU1","elec",type,reg,t)= 0;
2437  *capital.up("H2", "NH3", type,reg, t)$(year(t)< 2020)= 0;
2438   
2439  *en_conv.fx("NH3", "trsp", "0", reg, t) =0;
2440  *engines.fx(trsp_fuel, engine_type, car_truck_ships, reg,t)$(en_conv.l(trsp_fuel, "trsp", "0", reg,t)=0)=0;
2441   
2442  *MOL: These constraints are set to  callibrate the model to real data. It is important to note that setting the emissions as fix does not work, as the model might find it very difficult to solve it;
2443  C_emission.up(reg,"2010")=1.05*emissions_2010(reg);
2444   
2445   
2446  C_emission.up(NDC_2050,t)$(year(t)> 2040)=0;
2447  C_emission.up(NDC_2060,t)$(year(t)> 2050)=0;
2448  C_emission.up(NDC_2070,t)$(year(t)> 2060)=0;
2449   
2450   
2451  *supply_1.lo(calibfuels, reg, "2010") = callibsupply_2010(reg, calibfuels);
2452  *en_conv.lo(calibration_set, "elec", "0", reg, "2010") = 0.95*el_2010(reg, calibration_set)/(effic(calibration_set, "elec", "0", reg, "2010")+0.000001);
2453  *en_conv.up(calibration_set, "elec", "0", reg, "2010") = 1.05*el_2010(reg, calibration_set)/(effic(calibration_set, "elec", "0", reg, "2010")+0.000001);
2454  *en_conv.lo("wind", "elec", "0", reg, "2020") = wind_2020(reg)/effic("wind", "elec", "0", reg, "2020");
2455  *en_conv.lo("solar", "elec", "0", reg, "2020") = solar_pv_2020(reg)/effic("solar", "elec", "0", reg, "2020");
2456   
2457  en_conv.fx("wind", "elec", "0", reg, "2020") = 1*(wind_2020(reg)/effic("wind", "elec", "0", reg, "2020"));
2458  en_conv.fx("solar", "elec", "0", reg, "2020") = 1*(solar_pv_2020(reg)/effic("solar", "elec", "0", reg, "2020"));
2459   
2460  *en_conv.lo("wind", "elec", "0", reg, "2020") = 0.95*(wind_2020(reg)/effic("wind", "elec", "0", reg, "2020"));
2461  *en_conv.lo("solar", "elec", "0", reg, "2020") = 0.95*(solar_pv_2020(reg)/effic("solar", "elec", "0", reg, "2020"));
2462  en_conv.lo("EU4", "elec", "0", reg, "2020") = nuclear_2020(reg)/effic("EU4", "elec", "0", reg, "2020");
2463  en_conv.up("wind", "elec", "0", reg, "2020") = wind_2020(reg)/effic("wind", "elec", "0", reg, "2020")+0.001;
2464  en_conv.up("solar", "elec", "0", reg, "2020") = solar_pv_2020(reg)/effic("solar", "elec", "0", reg, "2020")+0.001;
2465  en_conv.up("EU4", "elec", "0", reg, "2020") = nuclear_2020(reg)/effic("EU4", "elec", "0", reg, "2020")+0.001;
2466  en_conv.up("hydro", "elec", "0", reg, "2020") = hydro_2020(reg)/effic("hydro", "elec", "0", reg, "2020");
2467   
2468  en_conv.lo("wind", "elec", "0", reg, "2030") = (wind_2030(reg)/effic("wind", "elec", "0", reg, "2030"));
2469  en_conv.lo("solar", "elec", "0", reg, "2030") = (solar_pv_2030(reg)/effic("solar", "elec", "0", reg, "2030"));
2470   
2471  EN_CONV.fx("bio","dist_heat","0",reg,t) = min_bio(reg,t);
2472  *EN_CONV.fx("H2", "NH3", type,reg, t)$(year(t)< 2030)= 0;
