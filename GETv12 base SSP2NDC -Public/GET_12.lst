2106  *--------------------emissions, capture, utlisation and storage------------------------------------------
2107   
2108   
2109  emiss_upstream_Q(reg,t)..
2110  emiss_upstream(reg,t) =E= sum(en_out $ (not sameas(en_out,'trsp')), (sum((en_in, type), en_conv(en_in,en_out, type,reg,t)
2111           *(emis_fact(en_in)-emis_fact(en_out)*effic(en_in, en_out, type,reg,t)))))
2112           - C_strg_tot(reg,t) + sum(en_out, (sum((natural_gas, type), en_conv(natural_gas,'CH4', type,reg,t)))*WTT_CH4)
2113           + sum(en_out, (sum((en_in, type), en_conv('LCH4','trsp', type,reg,t))+sum((en_in, type), en_conv('CH4','trsp', type,reg,t))+sum((en_in, type), en_conv('LCH4','trsp', type,reg,t)))*Distrib_LCH4);
2114   
2115   
2116   
2117  shipping_emis2(heavy_mode,reg,t)..
2118   ship_emis2(heavy_mode,reg,t)=e= sum((trsp_fuel, engine_type), trsp_energy(trsp_fuel, engine_type, heavy_mode, reg,t) *emis_fact2(trsp_fuel));
2119   
2120  shipping_emis(reg,t)..
2121   ship_emis(reg,t)=e=sum(heavy_mode,ship_emis2(heavy_mode,reg,t))
2122                      +(sum(heavy_mode, trsp_energy ("LCH4", "0", heavy_mode,reg, t)*extra_emis_CH4(heavy_mode)))
2123                      +(sum(heavy_mode, trsp_energy ("NH3", "0", heavy_mode,reg, t)* TTW_N2O));
2124   
2125  transport_emis(reg,t)..
2126  transp_emis(reg,t) =e=sum(engine_type, (sum((trsp_fuel, trsp_mode)$ (not heavy_mode (trsp_mode)), trsp_energy(trsp_fuel, engine_type, trsp_mode, reg,t)*emis_fact2(trsp_fuel))));
2127   
2128  emission_Q(reg,t)..
2129  C_emission(reg,t) =E= emiss_upstream(reg,t)+ ship_emis(reg,t)+transp_emis(reg,t);
2130   
2131   
2132  NDC_Q1(NDC_2050,t)..
2133  C_emission(NDC_2050,t)$(year (t) > 2030)=l=0.5*C_emission(NDC_2050,"2020");
2134  NDC_Q2(NDC_2060,t)..
2135  C_emission(NDC_2060,t)$(year (t) > 2040)=l=0.4*C_emission(NDC_2060,"2020");
2136  NDC_Q3(NDC_2070,t)..
2137  C_emission(NDC_2070,t)$(year (t) > 2050)=l=0.4*C_emission(NDC_2070,"2020");
2138   
2139  carbon_balance_Q(reg,t)..
2140  en_conv("H2","MeOH","0", reg, t)*emis_fact("MeOH")* effic("H2","MeOH","0",reg,t)
2141      +en_conv("H2","LCH4","0", reg, t)*emis_fact("LCH4")* effic("H2","LCH4","0",reg,t)
2142      =e=  C_capt_tot(reg,t)-C_strg_tot(reg,t) ;
2143   
2144  q_tot_emis(t)..
2145           sum(reg, C_emission(reg,t))=e=Tot_emis(t)     ;
2146   
2147  hist_emission(t_h)..  Tot_emis(t_h) =E= (hist_fos_emis(t_h)+HIST_luc_EMIS(t_h))*3.7    ;
2148   
2149  agg_emis_Q..
2150      agg_emis =E= sum((t,reg), t_step * C_emission(reg, t));
