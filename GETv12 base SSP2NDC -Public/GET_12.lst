1252   
1253  cost_inv(en_in, en_out, type, t) $ (((ord(t)-1)*t_step/t_tech_plant(en_in, en_out, type)) < 1) =
1254      cost_inv_0(en_in, type, en_out)-((cost_inv_0(en_in, type, en_out)-cost_inv_base(en_in, type, en_out))* (ord(t)-1)*t_step/t_tech_plant(en_in, en_out, type)) ;
1255   
1256  cost_inv(en_in, en_out, type, t) $ (((ord(t)-1)*t_step/t_tech_plant(en_in, en_out, type)) >= 1) =
1257   cost_inv_base(en_in, type, en_out);
1258   
1259  * D:o, and basic vehicle cost added
1260  cost_eng(trsp_fuel, engine_type, trsp_mode, t) =
1261   
1262  *cost_eng_base(road_fuel, engine_type, car_truck_ships)
1263  *             + vehicle_cost(car_truck_ships) ;
1264   
1265   max( cost_eng_base(trsp_fuel, engine_type, trsp_mode),
1266      cost_eng_0(trsp_fuel, engine_type, trsp_mode) -
1267      (cost_eng_0(trsp_fuel, engine_type, trsp_mode)-cost_eng_base(trsp_fuel, engine_type, trsp_mode))*
1268      ((ord(t)-1)*t_step/t_tech_eng(trsp_fuel, engine_type, trsp_mode)) )
1269      + vehicle_cost(trsp_mode);
1270   
1271  cost_inv_mod(en_in, en_out, type, t) = cost_inv(en_in, en_out, type, t);
1272  *    (r_invest + 1/life_plant(en_in, en_out, type))/(r+1/life_plant(en_in, en_out, type));
1273   
1274  cost_eng_mod(trsp_fuel, engine_type, trsp_mode, t) = cost_eng(trsp_fuel, engine_type, trsp_mode, t)          ;
1275  *    (r_invest + 1/life_eng(road_fuel, engine_type, car_or_truck))/(r+1/life_eng(road_fuel, engine_type, car_or_truck));
1276   
1277  cost_infra_mod(trsp_fuel, trsp_mode) = cost_infra(trsp_fuel, trsp_mode)         ;
1278  *    (r_invest + 1/life_infra(new_trsp_fuel)) / (r + 1/life_infra(new_trsp_fuel))
1279   
1280   
      *MOL:Test of higher import cost, in order to limit the trade between regions - conflictual for liquidfuelspaper.
      import_cost(second_in) = 5 * import_cost(second_in);
