1517   
1518  *### supply and conversion to delivered energy forms ###
1519   
1520  supply_pot_Q(primary, reg,t)..
1521      supply_pot(primary, reg,t) =G= supply_1(primary,reg, t);
1522   
1523  supply_1_Q(primary,reg, t)..
1524      supply_1(primary, reg,t)  =E= sum( (type, en_out), en_conv(primary, en_out, type, reg, t) );
1525   
1526   
1527  *export_import_balance(second_in, t)..
1528  *sum(reg, export(second_in, reg,t))=e=sum(reg, import( second_in, reg, t));
1529   
1530  *$ontext
1531  export_import_balance_1(second_in, reg_exp, t)..
1532           export(second_in, reg_exp,t)=e=sum(reg_imp, import_from(second_in, reg_imp, reg_exp, t));
1533   
1534  export_import_balance_2(second_in, reg_imp, t)..
1535           import(second_in, reg_imp,t)=e=sum(reg_exp, import_from(second_in, reg_imp, reg_exp, t));
1536   
1537  *$offtext
1538   
1539  supply_2_Q(second_in,reg, t)..
1540      supply_2(second_in, reg,t)-export(second_in, reg,t)+import(second_in,reg,t) =e= sum( (type, en_out), en_conv(second_in, en_out, type,reg, t) ) ;
1541   
1542  supply_loop_Q(second_in,reg,t)..
1543      supply_2(second_in, reg,t) =L= energy_prod(second_in, reg,t);
1544   
1545  energy_prod_Q(en_out,reg,t) $ (not sameas(en_out,"elec"))..
1546      energy_prod(en_out,reg,t) =E=
1547          sum((type,en_in), en_conv(en_in,en_out,type,reg, t) * effic(en_in, en_out, type, reg,t))
1548          + supply_sec(en_out,reg,t);
1549   
1550  energy_prod_elec_Q(reg,t)..
1551      energy_prod("elec",reg,t) =E=
1552          sum((type,en_in) $ (not sameas(en_in,"solar") and not sameas(en_in,"wind")),
1553                              en_conv(en_in,"elec",type,reg,t) * effic(en_in,"elec",type,reg,t))
1554          + supply_sec("elec",reg,t) - elec_losses(reg,t);
1555   
1556  energy_prod2_Q(en_in, en_out, type, reg,t)..
1557      energy_prod2(en_in, en_out, type,reg,t) =E=
1558           en_conv(en_in, en_out, type,reg, t) * effic(en_in, en_out, type, reg,t)+supply_sec2(en_in, en_out, type, reg,t);
1559   
1560   
1561  *MOL: the below equation constraints the en_prod from nuclear, taking into account the the supply_2 (imports and exports of each region)
1562  *For each timestep t+1, the total energy supplied by nuclear cannot increase versus to the time step t more than the energy produced by one reactor of 1 GW per region, assuming a load factor of 0.80
1563  *0.025 EJ is equivalent to 1 GW reactor to be built in each region, in a period of 10 years.
1564  *1 GW = 0.001 TW * 365 d * 24 h * 0.8 (lf) = 7 TWh / 277.8 = 0.025 EJ
1565  nuclear_gen_Q(second_in,reg,t) $ (nuclear_just(second_in))..
1566   energy_prod(second_in, reg,t+1)  =l= energy_prod(second_in, reg,t) + 0.025;
1567   
1568  reserves_Q(stock, reg).. sum(t, t_step*supply_1(stock, reg,t) )=L= supply_pot_0(stock, reg);
1569   
1570  no_stock_Q(no_stock,reg,t) ..
1571  energy_prod(no_stock, reg,t)=e= sum( (type, en_out), en_conv(no_stock, en_out, type,reg, t) ) ;
1572   
1573  no_stock2_Q(no_stock2,reg,t) ..
1574  energy_prod(no_stock2, reg,t)-export(no_stock2, reg,t)+import(no_stock2,reg,t)=e= sum( type,  en_conv(no_stock2, "trsp", type,reg, t) );
1575  *sum( (type, en_in), en_conv(en_in, no_stock2, type,reg, t)* effic(en_in, no_stock2, type, reg,t)-export(no_stock2, reg,t)+import(no_stock2,reg,t)=e= sum( type,  en_conv(no_stock2, "trsp", type,reg, t) ;
1576   
1577  waste_fl_Q(wastes, reg, t) ..
1578  waste_fl(wastes, reg, t)  =e= (sum((en_in), en_conv (en_in, wastes, "0", reg, t)* effic(en_in, wastes, "0", reg, t))) ;
1579   
1580  q_Saved_pu(reg,t)$(year(t)>=2000)..
1581           Pu_stock(reg, t+1)=e= Pu_stock(reg, t)+en_conv ("Rep2", "PuR", "0", reg, t)* effic("Rep2","PuR", "0", reg, t)-sum(en_out, en_conv ("PuR", en_out, "0", reg, t)  )    ;
1582   
1583  q_start_pu(reg)..
1584           Pu_stock(reg, "2010")=e= Pu_start( reg);
1585   
1586  agg_waste_Q(wastes)..
1587      agg_waste(wastes) =E= sum((t,reg), t_step * waste_fl(wastes, reg, t));
1588   
1589  *### energy delivered ###
1590   
1591  energy_deliv_Q(en_out, reg,t)..
1592      energy_deliv(en_out, reg,t) =e= energy_prod(en_out,reg, t)  -supply_2(en_out,reg, t);
1593   
1594  supply_sec_Q(energy,reg,t)  ..
1595  supply_sec(energy,reg,t)=e= sum( (en_in, type, en_out), en_conv(en_in, en_out, type,reg, t)*heat_effic(en_in, type, en_out, energy) );
1596   
1597  supply_sec2_Q(en_in, energy,type, reg,t)  ..
1598  supply_sec2(en_in, energy, type,reg,t)=e= sum( ( en_out), en_conv(en_in, en_out, type,reg, t)*heat_effic(en_in, type, en_out, energy) );
1599   
1600  Breeder_lag_Q(type,reg) ..
1601  en_conv("Rep3", "FBF", type,reg, "2030")=e=en_conv("Rep2", "FBF", type,reg, "2030")*effic("Rep2", "FBF", type, reg,"2030")+ en_conv("Pu", "FBF", type,reg, "2030")*effic("Pu", "FBF", type, reg,"2030")+ en_conv("EU4", "FBF", type,reg, "2030")*effic("EU4", "FBF", type, reg,"2030")  ;
1602   
1603  Breeder_lag_Q2(type,reg, t) $(year(t)>2030) ..
1604  en_conv("Rep3", "FBF", type,reg, t)=e=en_conv("Rep2", "FBF", type,reg, t)*effic("Rep2", "FBF", type, reg,t)+ en_conv("Pu", "FBF", type,reg, t)*effic("Pu", "FBF", type, reg,t)+ en_conv("EU4", "FBF", type,reg, t)*effic("EU4", "FBF", type, reg,t)+ en_conv("Rep3", "FBF", type,reg, t-1)  ;
1605   
       
      *Reprocessing delays for nuclear
       
      supply_sec_Q(energy,reg,t) $ ((not sameas(energy, 'BrProd')) and ( not sameas (energy, "sLWRf"))) ..
         supply_sec(energy,reg,t)=e= sum( (en_in, type, en_out), en_conv(en_in, en_out, type,reg, t)*heat_effic(en_in, type, en_out, energy) );
       
      supply_sec2_Q(en_in, energy,type, reg,t) $ ((not sameas(energy, 'BrProd')) and ( not sameas (energy, "sLWRf"))) ..
      supply_sec2(en_in, energy, type,reg,t)=e= sum( ( en_out), en_conv(en_in, en_out, type,reg, t)*heat_effic(en_in, type, en_out, energy) );
       
      supply_sec_breeder_lag_Q(reg,t) ..
         supply_sec('BrProd',reg,t)=e= sum( (en_in, type, en_out), en_conv(en_in, en_out, type,reg, t-1)*heat_effic(en_in, type, en_out, 'BrProd') );
       
      supply_sec_breeder_lag2_Q(en_in,type, reg,t) ..
      supply_sec2(en_in, "BrProd",type, reg,t)=e= sum( ( en_out), en_conv(en_in, en_out, type,reg, t-1)*heat_effic(en_in, type, en_out, "BrProd") );
       
      supply_sec_rep_lag_Q(reg,t) ..
         supply_sec('sLWRf',reg,t)=e= sum( (en_in, type, en_out), en_conv(en_in, en_out, type,reg, t-1)*heat_effic(en_in, type, en_out, 'sLWRf') );
       
      supply_sec_rep_lag2_Q(en_in,type, reg,t) ..
      supply_sec2(en_in, "sLWRf",type,reg,t)=e= sum( (  en_out), en_conv(en_in, en_out, type,reg, t-1)*heat_effic(en_in, type, en_out, "sLWRf") );
1628   
1629  *--------------transportation module--------------------------
1630   
1631  transp_q(trsp_fuel,reg,t)..
1632           sum( (trsp_mode, engine_type), trsp_energy(trsp_fuel, engine_type, trsp_mode, reg,t) )=e=
1633           sum(type, en_conv(trsp_fuel, "trsp", type, reg,t)*effic(trsp_fuel, "trsp", type,reg,t));
1634   
1635  trsp_demand_Q(trsp_mode, reg,t)..
1636      trsp_demand(trsp_mode, reg,t) =e= sum( (trsp_fuel, engine_type),
1637      trsp_energy(trsp_fuel, engine_type, trsp_mode,reg, t)*trsp_conv(trsp_fuel, engine_type, trsp_mode) );
1638   
1639  vehicle_lim_FCREEV_Q(FC_fuels, engine_type, car_or_truck, reg,t)..
1640      trsp_energy(FC_fuels, "FCREEV", car_or_truck, reg,t) =e=
1641          engines(FC_fuels, "FCREEV", car_or_truck, reg,t)/
1642             num_veh(car_or_truck,reg, t)*(1-elec_frac_PHEV(car_or_truck))*
1643                trsp_demand(car_or_truck,reg, t)/(trsp_conv(FC_fuels, "FCREEV", car_or_truck)+0.0001);
1644   
1645  elec_frac_FCREEV_Q(car_or_truck, engine_type, reg,t)..
1646       sum(FC_fuels, trsp_energy(FC_fuels, "FCREEV", car_or_truck, reg, t)*
1647           trsp_conv(FC_fuels, "FCREEV", car_or_truck))/(1-elec_frac_PHEV(car_or_truck)) =e=
1648              trsp_energy("elec", "FCREEV", car_or_truck, reg, t)*
1649                 trsp_conv("elec", "FCREEV", car_or_truck)/(elec_frac_PHEV(car_or_truck));
1650   
1651  vehicle_lim_Q(trsp_fuel, non_phev, trsp_mode_no_train, reg,t)..
1652      trsp_energy(trsp_fuel, non_phev, trsp_mode_no_train, reg,t)*trsp_conv(trsp_fuel, non_phev, trsp_mode_no_train) =l=
1653          engines(trsp_fuel, non_phev, trsp_mode_no_train, reg, t)/num_veh(trsp_mode_no_train,reg, t)*
1654          trsp_demand(trsp_mode_no_train, reg,t);
1655   
1656  vehicle_lim_PHEV_Q(road_fuel_liquid,engine_type, car_or_truck, reg,t)..
1657      trsp_energy(road_fuel_liquid, "PHEV", car_or_truck, reg,t) =e=
1658          engines(road_fuel_liquid, "PHEV", car_or_truck, reg,t)/
1659             num_veh(car_or_truck,reg, t)*(1-elec_frac_PHEV(car_or_truck))*
1660                trsp_demand(car_or_truck,reg, t)/(trsp_conv(road_fuel_liquid, "PHEV", car_or_truck)+0.0001);
1661   
1662  elec_frac_PHEV_Q(car_or_truck,  engine_type,reg,t)..
1663       sum(road_fuel_liquid, trsp_energy(road_fuel_liquid, "PHEV", car_or_truck,reg, t)*
1664           trsp_conv (road_fuel_liquid, "PHEV", car_or_truck))/(1-elec_frac_PHEV(car_or_truck)) =e=
1665              trsp_energy( "elec", "PHEV", car_or_truck,reg, t)*
1666                 trsp_conv ("elec", "PHEV", car_or_truck)/(elec_frac_PHEV(car_or_truck));
1667   
1668  lim_elec_veh(car_or_truck,elec_veh,reg,t)..
1669           sum(trsp_fuel, engines(trsp_fuel, elec_veh, car_or_truck, reg,t))=l=
1670            frac_engine(elec_veh, car_or_truck)*num_veh(car_or_truck, reg,t) ;
1671   
1672   
1673  *To make sure there is 5% pilot fuel for H2 and NH3 ICE
1674  pilot_fuel_Q(engine_type,heavy_mode, reg,t)..
1675   sum(can_be_pilot, trsp_energy(can_be_pilot, "0", heavy_mode, reg,t) )=G=0.05*sum(need_pilot, trsp_energy(need_pilot, "0", heavy_mode, reg,t));
1676   
1677  *### balance demand and supply ###
1678   
1679  Deliv_Q(sector,reg,t) $ (not sameas(sector,"elec")and not sameas(sector,"solid_heat") ) ..
1680      energy_deliv(sector,reg,t) =e= dem(sector,reg,t);
1681   
1682  Deliv_Solid_heat_Q("solid_heat",reg, t)..
1683  energy_deliv ("solid_heat", reg, t)  =e=  dem ("solid_heat", reg, t)+ C_capt_air (reg, t)*heat_CO2aircapture;
1684   
1685   
1686  *----------------electricity sector----------------------------
1687  * to do:
1688  * hydro - split between storage & run of river, annual inflow, put x% of hydro storage in run of river to reflect regulations
1689  * sliced central_heat sector (may overinvest in capacity to profit from low elec prices)
1690  * timeshifting of demand in central_heat, solid_heat, non_solid_heat, trsp (implement as a storage technology)
1691  * BUT only central_heat and trsp matter, other sectors phase out electricity
1692  * storage technologies with characteristic timescales (pumped hydro, compressed air, batteries)
1693   
1694  Elec_Deliv_Dem_Q(reg,slice,t)..
1695      elec_deliv(reg,slice,t) =e= elec_dem(reg,slice,t)
1696  *+0.053*en_conv("h2", "NH3", "0",reg, t)/ effic("h2", "NH3", "0",reg, t)* slice_lng(reg,slice) * sliced_demand(reg,slice)
1697  ;
1698   
1699  elec_deliv_Q(reg,slice,t)..
1700      elec_deliv(reg,slice,t) =e= energy_deliv("elec",reg, t) * slice_lng(reg,slice) * sliced_demand(reg,slice)+C_capt_air (reg, t)*El_DAC;
1701   
1702  elec_use_Q(elecsector,reg,slice,t)..
1703      elec_use(elecsector,reg,slice,t)=e=
1704          en_conv("elec",elecsector,"0",reg,t) * slice_lng(reg,slice) * sliced_demand(reg,slice);
1705   
1706  sliced_elec_balance(reg,slice,t)..
1707  * avoid double counting solar & wind (subtechs represented both individually & collectively)
1708      sum((en_in,type) $ (not sameas(en_in,"solar") and not sameas(en_in,"wind")), elec_gen(en_in,type,reg,slice,t)) =e=
1709          elec_dem(reg,slice,t)
1710          + sum(elecsector, elec_use(elecsector,reg,slice,t))
1711          - sum((storage_tech, slice2), storage_slice_transfer(storage_tech,reg,slice2,slice,t) * effic(storage_tech,"elec","0",reg,t))
1712          + sum((storage_tech, slice2), storage_slice_transfer(storage_tech,reg,slice,slice2,t))
1713          + H2_prod("elec","0",reg,slice,t) / effic("elec","H2","0",reg,t);
1714   
1715  total_losses_Q(reg,t)..
1716      elec_losses(reg,t) =E= sum((storage_tech,slice,slice2), storage_slice_transfer(storage_tech,reg,slice2,slice,t) * (1-effic(storage_tech,"elec","0",reg,t)));
1717   
1718  elec_gen_Q(en_in,type,reg,t)..
1719      sum(slice, elec_gen(en_in,type,reg,slice,t)) =e= en_conv(en_in,"elec",type,reg,t) * effic(en_in,"elec",type,reg,t);
1720   
1721  * equation rearranged to avoid division-by-zero error if a slice has zero length
1722  thermal_limit(thermalelec,type,reg,slice,slice2,t)..
1723  *        elec_gen(thermalelec,type,reg,slice,t) / slice_lng(reg,slice) =G= ramp_lim(thermalelec,type) * elec_gen(thermalelec,type,reg,slice2,t) / slice_lng(reg,slice2);
1724          elec_gen(thermalelec,type,reg,slice,t) * slice_lng(reg,slice2) =G= ramp_lim(thermalelec,type) * elec_gen(thermalelec,type,reg,slice2,t) * slice_lng(reg,slice);
1725   
1726  elec_capital_lim_class(class_tech,class,reg,slice,t) ..
1727      elec_gen_class(class_tech,class,reg,slice,t) =L= capital_class(class_tech,class,reg,t) *
1728                                         lfsl(class_tech,class,reg,slice) * Msec_per_year * slice_lng(reg,slice);
1729   
1730  * make exception for hydro
1731  elec_capital_lim_Q(en_in,type,reg,slice,t) $ (not is_class_tech(en_in)) ..
1732      elec_gen(en_in,type,reg,slice,t) =L= capital(en_in,"elec",type,reg,t) *
1733                                         lfs(en_in,type,reg,slice,"elec") * Msec_per_year * slice_lng(reg,slice);
1734   
1735  * above constraint invalid for storage techs (lfs = 0), here's the real one
1736  * unit of storage_slice_transfer_times is hours/year, capital is TW and all energy units are EJ
1737  storage_capital_lim_Q(storage_tech,reg,slice,slice2,t)..
1738      storage_slice_transfer(storage_tech,reg,slice,slice2,t) =L= capital(storage_tech, "elec","0",reg,t) *
1739                                          storage_slice_transfer_times(storage_tech,reg,slice,slice2) * 3600 / 1e6;
1740   
1741  capital_class_limit(class_tech,class,reg,t)..
1742      capital_class(class_tech,class,reg,t) =L= class_capacity_limit(class_tech, class, reg);
1743   
1744  elec_class_aggregation(class_tech,reg,slice,t)..
1745      sum(class, elec_gen_class(class_tech,class,reg,slice,t)) =E= elec_gen(class_tech,"0",reg,slice,t);
1746   
1747  capital_class_aggregation(class_tech,reg,t)..
1748      sum(class, capital_class(class_tech,class,reg,t)) =E= capital(class_tech,"elec","0",reg,t);
1749   
1750  wind_elec_aggregation(reg,slice,t)..
1751      elec_gen("windonshoreA","0",reg,slice,t) + elec_gen("windonshoreB","0",reg,slice,t) +
1752                  elec_gen("windoffshore","0",reg,slice,t) =E= elec_gen("wind","0",reg,slice,t);
1753   
1754  wind_capital_aggregation(reg,t)..
1755      capital("windonshoreA","elec","0",reg,t) + capital("windonshoreB","elec","0",reg,t) +
1756                  capital("windoffshore","elec","0",reg,t) =E= capital("wind","elec","0",reg,t);
1757   
1758  pv_elec_aggregation(reg,slice,t)..
1759      elec_gen("pvrooftop","0",reg,slice,t) + elec_gen("pvplantA","0",reg,slice,t) +
1760                  elec_gen("pvplantB","0",reg,slice,t) =E= elec_gen("solar","0",reg,slice,t);
1761   
1762  pv_capital_aggregation(reg,t)..
1763      capital("pvrooftop","elec","0",reg,t) + capital("pvplantA","elec","0",reg,t) +
1764                  capital("pvplantB","elec","0",reg,t) =E= capital("solar","elec","0",reg,t);
1765   
1766  csp_elec_aggregation(reg,slice,t)..
1767      elec_gen("cspplantA","0",reg,slice,t) + elec_gen("cspplantB","0",reg,slice,t)
1768                                                      =E= elec_gen("solar","cg",reg,slice,t);
1769   
1770  csp_capital_aggregation(en_in,reg,t)..
1771      capital("cspplantA","elec","0",reg,t) + capital("cspplantB","elec","0",reg,t)
1772                                                      =E= capital("solar","elec","cg",reg,t);
1773   
1774  *### Hydrogen ###
1775   
1776  H2_prod_balance_Q(sliced_H2,reg,type,t)..
1777      sum(slice, H2_prod(sliced_H2,type,reg,slice,t)) =e= en_conv(sliced_H2,"H2",type,reg,t) * effic(sliced_H2,"H2",type,reg,t);
1778   
1779  H2_capital_lim1(sliced_H2,type,reg,slice,t) ..
1780      H2_prod(sliced_H2,type,reg,slice,t) $ (not sameas(sliced_H2,"solar"))=L=
1781          capital(sliced_H2,"H2",type,reg,t) * lfs(sliced_H2,type,reg,slice,"H2") * Msec_per_year * slice_lng(reg,slice);
1782   
1783  *Solar hydrogen
1784   
1785  H2_capital_lim_class(class,reg,slice,t)..
1786      H2_prod_class(class,reg,slice,t) =L= capital_class_H2( class,reg,t)* lfsl_H2(class,reg,slice)* Msec_per_year * slice_lng(reg,slice);
1787   
1788  H2_capital_class_limit(class,reg,t)..
1789      capital_class_H2(class,reg,t) =L= class_capacity_limit_H2(class, reg);
1790   
1791  H2_class_aggregation(reg,slice,t)..
1792      sum(class, H2_prod_class(class,reg,slice,t)) =E= H2_prod("solar","0",reg,slice,t);
1793   
1794  H2_capital_class_aggregation(reg,t)..
1795      sum(class, capital_class_H2(class,reg,t)) =E= capital("solar","H2","0",reg,t);
1796   
1797  *### use limited by capital ###
1798   
1799  capital_lim_Q(en_in, en_out, type,reg, t) $ (not sameas(en_out, "elec") and not sameas(en_out, "H2")) ..
1800      en_conv(en_in, en_out, type, reg,t)* effic(en_in, en_out, type, reg,t) =L= capital(en_in, en_out, type,reg, t)
1801                                         *lf(en_in, type, en_out)*Msec_per_year;
1802   
1803   
1804  infra_lim_Q(trsp_fuel, reg,t)..
1805      sum(type, en_conv(trsp_fuel, "trsp", type, reg,t)* effic(trsp_fuel, "trsp", type,reg, t))
1806            =L= infra(trsp_fuel,reg, t)*lf_infra(trsp_fuel)*Msec_per_year;
1807   
1808  *### investments and depreciation ###
1809   
1810  init_invest_Q(en_in, en_out, type, reg,init_year)..
1811      capital(en_in, en_out, type, reg,init_year) =E= init_capital(en_in, en_out, type, reg)
1812                     + t_step *cap_invest(en_in, en_out, type,reg, init_year);
1813   
1814  capital_Q(en_in, en_out, type, reg,t+1)..
1815      capital(en_in, en_out, type, reg,t+1) =E= t_step * cap_invest(en_in, en_out, type, reg,t+1)
1816             + capital(en_in, en_out, type, reg,t)*exp(t_step*log(1-1/life_plant(en_in, en_out, type)));
1817   
1818  engines_Q(trsp_fuel, engine_type, trsp_mode_no_train, reg,t+1)..
1819      engines(trsp_fuel, engine_type, trsp_mode_no_train,reg, t+1) =E= t_step * eng_invest(trsp_fuel, engine_type, trsp_mode_no_train,reg, t+1)
1820             + engines(trsp_fuel, engine_type, trsp_mode_no_train, reg,t)*
1821               exp(t_step*log(1-1/life_eng(trsp_fuel, engine_type, trsp_mode_no_train)));
1822   
1823  infra_Q(trsp_fuel,reg, t+1)..
1824      infra(trsp_fuel, reg,t+1) =E= t_step * sum(trsp_mode_no_train, infra_invest(trsp_fuel,trsp_mode_no_train,reg, t+1))
1825             + infra(trsp_fuel,reg, t) * exp(t_step*log(1-1/life_infra(trsp_fuel)));
1826   
1827   
1828  *### annual and total costs ###
1829   
1830  cost_fuel_Q(reg,t)..
1831      cost_fuel(reg,t) =E= sum(fuels, supply_1(fuels, reg,t)*price(fuels, reg))+sum(second_in, import(second_in, reg,t)*import_cost(second_in))
1832           +sum((reg_exp, second_in), import_from(second_in, reg, reg_exp, t)*distance(reg, reg_exp)*imp_cost_lin(second_in));
1833  *;
1834   
1835  Ship_levy_Q(t)..
1836  ship_levy_cost(t)=e= sum(reg, ship_emis(reg,t))*ship_levy(t);
1837  *-------------FMK 20250511---------------Activate for all scenarios except for 2tier mechanism and feebate for shipping----------
1838  *$ontext
1839  cost_cap_Q(reg,t)..
1840   
1841      cost_cap(reg,t) =E=
1842      sum( (en_in, en_out, type),
1843          cap_invest(en_in, en_out, type,reg, t)*cost_inv(en_in, en_out, type, t) )+
1844      sum( (trsp_fuel, engine_type, trsp_mode_no_train),
1845          eng_invest(trsp_fuel, engine_type, trsp_mode_no_train, reg,t)*(cost_eng(trsp_fuel, engine_type, trsp_mode_no_train, t)) )+
1846      sum( (trsp_fuel,trsp_mode_no_train),
1847          infra_invest(trsp_fuel,trsp_mode_no_train, reg, t)*cost_infra_mod(trsp_fuel, trsp_mode_no_train) );
1848  *$offtext
1849  *--------------FMK 20250511--------------Activate only for feebate  for shipping-----------------------------------------------
      cost_feebate_Q1(reg,t)..
          cost_feebate_fossil(reg,t) =E=sum((trsp_fuel, engine_type, heavy_mode)$(not zero_fuels(trsp_fuel)),
              eng_invest(trsp_fuel, engine_type, heavy_mode, reg,t)*(cost_eng(trsp_fuel, engine_type, heavy_mode, t)) );
      cost_feebate_Q2(reg,t)..        
          cost_feebate_zero_fuel(reg,t) =E= sum((zero_fuels, engine_type, heavy_mode),
              eng_invest(zero_fuels, engine_type, heavy_mode, reg,t)*(cost_eng(zero_fuels, engine_type, heavy_mode, t)) )-feebate(reg,t);
       
      feebate_reg_Q(t)..
              ship_levy_cost(t)*0.2=E=sum(reg, feebate(reg,t));       
       
      cost_cap_Q(reg,t)..
          cost_cap(reg,t) =E=
          sum( (en_in, en_out, type),
              cap_invest(en_in, en_out, type,reg, t)*cost_inv(en_in, en_out, type, t) )+
          sum( (trsp_fuel, engine_type, trsp_mode_no_train)$(not heavy_mode(trsp_mode_no_train)),
              eng_invest(trsp_fuel, engine_type, trsp_mode_no_train, reg,t)*(cost_eng(trsp_fuel, engine_type, trsp_mode_no_train, t)) )+
          sum( (trsp_fuel,trsp_mode_no_train),
              infra_invest(trsp_fuel,trsp_mode_no_train, reg, t)*cost_infra_mod(trsp_fuel, trsp_mode_no_train) )+
          cost_feebate_fossil(reg,t)+ cost_feebate_zero_fuel(reg,t);
       
1872   
1873  cost_C_strg_Q(t)..
1874      cost_C_strg(t) =E=   sum( reg, C_strg_tot(reg,t) )*cost_strg;
1875  *total cost of storing and transporting CO2
1876   
1877  cost_capt_air_Q(t)..
1878  cost_capt_air(t)=E=sum(reg, C_capt_air (reg, t))*CO2aircapt_cost;
1879  *total cost of capturing CO2 from air
1880   
1881   
1882  tax_Q(reg,t)..
1883      tax(reg,t) =E= C_emission(reg,t)*C_tax(reg,t);
1884   
1885   
1886  OM_cost_Q(t)..
1887      OM_cost(t) =E= sum( (en_in, en_out, type, reg), OM_cost_fr(en_in, en_out) * cost_inv(en_in, en_out, type, t) *
1888          en_conv(en_in, en_out, type,reg, t) * effic(en_in, en_out, type,reg, t) / Msec_per_year/(lf(en_in, type, en_out)+0.000001)) ;
1889   
1890  dist_cost_Q(t)..
1891        dist_cost(t)=e=sum( (en_in, type, en_out, reg), en_conv(en_in, en_out, type,reg, t)*infra_cost(en_in, type, en_out))
1892           +sum(reg, supply_sec("central_heat",reg,t)*district_cost);
1893   
1894  annual_cost_Q(t)..
1895      annual_cost(t) =E= sum(reg, cost_fuel(reg, t)) +
1896                       sum(reg, cost_cap(reg, t)) +
1897                       OM_cost(t) +
1898                       dist_cost(t) +
1899                       cost_C_strg(t) +
1900                       cost_C_bio_trsp(t)  +
1901                       cost_capt_air(t)+
1902                       sum(reg, tax(reg,t))
1903                       +ship_levy_cost(t) ;
1904   
1905  tot_cost_Q..
1906      tot_cost =E= sum(t, t_step * annual_cost(t)/((1+r)**(t_step*(ord(t)-1))));
1907   
1908  *### technology restrictions ###
1909   
1910  cogen_e_Q(reg,t)..
1911      sum( (cg_fuel, cg_type), en_conv(cg_fuel, "elec", cg_type,reg, t)*
1912                   heat_effic (cg_fuel, cg_type, "elec", "central_heat")) =L= cogen_fr_h * dem("central_heat",reg, t);
1913   
1914  max_solar_q(heat, reg,t)..
1915      en_conv("solar", heat, "0",reg,t)=l=dem(heat,reg,t)*max_solar(heat,reg)     ;
1916   
1917  max_heat_pump(heat,reg,t)..
1918      en_conv("elec", heat, "0",reg,t)=l=dem(heat,reg,t)*max_pump(heat,reg)     ;
1919   
1920  max_chips(reg,t)..
1921       sum(type,  en_conv("bio", "solid_heat", type,reg,t)*effic("bio", "solid_heat", type,reg, t))=l=dem("solid_heat",reg,t)*max_chip  ;
1922   
1923  max_feed_stock(feed,reg, t)..
1924       sum(type,  en_conv(feed, "feed-stock", type,reg,t)*effic(feed, "feed-stock", type,reg, t))=l=dem("feed-stock",reg,t)*max_feed(feed)  ;
1925   
1926   
1927  *### Expansion rate constraints ###
1928   
1929  supp_lim_Q(fuels, reg,t+1)..  supply_1(fuels, reg,t+1) =L=
1930      supply_1(fuels, reg,t) * (1+supply_lim)**t_step + init_supply;
1931   
1932  infra_lim1_Q(trsp_fuel, reg,t+1).. infra(trsp_fuel,reg, t+1) =L=
1933      infra(trsp_fuel, reg,t) * (1+infra_g_lim)**t_step+init_infra ;
1934   
       
      eng_g_lim_Q(trsp_fuel, engine_type,car_truck_ships,reg, t+1)..
               engines(trsp_fuel, engine_type, car_truck_ships,reg, t+1)/num_veh(car_truck_ships,reg,t+1)=L=
               marketshare_eng+engines(trsp_fuel, engine_type, car_truck_ships,reg, t)/num_veh(car_truck_ships,reg,t)   ;
       
      eng_g_lim_Q2(trsp_fuel, engine_type,car_truck_ships,reg, t+1)..
               engines(trsp_fuel, engine_type, car_truck_ships,reg, t+1)/num_veh(car_truck_ships,reg,t+1)=G=
               engines(trsp_fuel, engine_type, car_truck_ships,reg, t)/num_veh(car_truck_ships,reg,t)-marketshare_eng   ;
1945   
1946  eng_g_lim_Q4( engine_type,trsp_mode_no_train,reg, t+1)..
1947   sum (trsp_fuel, engines(trsp_fuel, engine_type, trsp_mode_no_train,reg, t+1))=L=
1948   sum(trsp_fuel, engines(trsp_fuel, engine_type, trsp_mode_no_train,reg, t))*(1+eng_g_lim)**t_step+init_eng;
1949   
1950  *Q_car_balance(trsp_mode,reg,t)$ (not sameas(trsp_mode, "f_rail") and not sameas(trsp_mode, "p_rail")and not sameas(trsp_mode, "p_air_short")and not sameas(trsp_mode, "p_air_medium")and not sameas(trsp_mode, "p_air_long")and not sameas(trsp_mode, "f_air"))..
1951  *sum((engine_type,trsp_fuel),engines(trsp_fuel, engine_type, trsp_mode,reg, t))=l= num_veh(trsp_mode,reg,t)+0.1;
1952   
1953  cap_g_lim_Q(en_in, en_out, type,reg, t+1)..
1954      cap_invest(en_in, en_out, type,reg, t+1) =L=
1955      cap_invest(en_in, en_out, type, reg,t) * (1+cap_g_lim)**t_step+init_plant;
