2099  CTRBE(t_a, t_b)..
2100      CARB_CTRB(t_a, t_b) =E= ( Tot_emis(t_b)/3.7 + FUT_LUC_EMIS(t_b)     )*GFUNC(t_a, t_b);
2101   
2102  ATM_CCONTE(t_a)..
2103      ATM_CCONT(t_a)=E=PRE_IND_CCONT+SUM(t_b,CARB_CTRB(t_a, t_b))*0.28/600*10;
