1074  parameter class_capacity_limit_H2(class, reg);
1075  class_capacity_limit("windonshoreA", class, reg) = caplimit_windonshoreA(class, reg) / 1000;
1076  class_capacity_limit("windonshoreB", class, reg) = caplimit_windonshoreB(class, reg) / 1000;
1077  class_capacity_limit("windoffshore", class, reg) = caplimit_windoffshore(class, reg) / 1000;
