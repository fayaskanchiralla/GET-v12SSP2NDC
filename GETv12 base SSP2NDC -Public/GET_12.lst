      annual_emis(reg,t)$(year(t)<2060)..
               C_emission(reg,t)=l=trajec(reg,t);
       
      q_global_cap(t)..
               sum(reg, C_emission(reg,t))=l=sum(reg,trajec(reg,t));
2161   
2162  *$ontext
